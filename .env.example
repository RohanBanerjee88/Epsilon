# Copy to .env for local runs, or set these as secrets in the Maritime dashboard.

# Required: your Anthropic API key (used for the plan + synthesis calls).
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the reasoning model (default: claude-sonnet-5).
RESEARCH_MODEL=claude-sonnet-5

# Optional: where per-user memory is stored (default matches the Dockerfile).
MEMORY_PATH=/data/memory.json

# Optional: port to listen on (Maritime may inject this automatically).
PORT=8080
