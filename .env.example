# Copy to .env for local runs, or set these values as deployment secrets.

# Required: used for the planning and synthesis calls.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional model and synthesis effort overrides.
RESEARCH_MODEL=claude-sonnet-5
RESEARCH_EFFORT=high

# Local default. Docker overrides this with /data/memory.json.
MEMORY_PATH=.data/memory.json
CARD_STORE_PATH=.data/cards.json

# Next.js development origins accepted by FastAPI.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# The production container defaults to 8080 and honors platform overrides.
PORT=8080
